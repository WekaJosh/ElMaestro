<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
<style>
  :root {
    --bg: #0e1116;
    --panel: #161b22;
    --border: #2d333b;
    --fg: #e6edf3;
    --muted: #8b949e;
    --accent: #58a6ff;
    --good: #3fb950;
    --warn: #d29922;
    --bad: #f85149;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg); color: var(--fg);
  }
  header {
    padding: 24px 32px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #161b22 0%, #0e1116 100%);
  }
  header h1 { margin: 0; font-size: 20px; letter-spacing: -0.01em; }
  header .sub { color: var(--muted); margin-top: 4px; font-size: 13px; }
  main { padding: 24px 32px; max-width: 1400px; margin: 0 auto; }
  section { margin-bottom: 32px; }
  section h2 { font-size: 14px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin: 0 0 12px; }
  .chart {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 16px;
  }
  table.diff {
    width: 100%;
    border-collapse: collapse;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    font-size: 13px;
  }
  table.diff th, table.diff td {
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  table.diff th { color: var(--muted); font-weight: 500; background: #0b0e13; }
  table.diff tr:last-child td { border-bottom: none; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  td.delta-pos { color: var(--good); }
  td.delta-neg { color: var(--bad); }
  td.delta-zero { color: var(--muted); }
  td.dim { color: var(--muted); }
  code { color: var(--accent); background: #0b0e13; padding: 1px 5px; border-radius: 4px; font-size: 12px; }
  footer { padding: 24px 32px; color: var(--muted); font-size: 12px; border-top: 1px solid var(--border); }
  .runs-key { display: flex; flex-wrap: wrap; gap: 16px; }
  .runs-key .pill { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 6px 12px; }
  .runs-key .pill.baseline { border-color: var(--accent); }
</style>
</head>
<body>

<header>
  <h1>{{ title }}</h1>
  <div class="sub">
    Comparing {{ runs|length }} run(s); baseline = <code>{{ baseline }}</code>
  </div>
</header>

<main>

<section>
  <h2>Runs</h2>
  <div class="runs-key">
    {% for run in runs %}
      <div class="pill {% if run.label == baseline %}baseline{% endif %}">
        <strong>{{ run.label }}</strong>
        <span style="color: var(--muted); margin-left: 8px;">
          {{ run.results|length }} spec(s) · <code>{{ run.run_dir }}</code>
        </span>
      </div>
    {% endfor %}
  </div>
</section>

<section>
  <h2>Throughput</h2>
  <div class="chart">{{ throughput_html | safe }}</div>
</section>

<section>
  <h2>IOPS</h2>
  <div class="chart">{{ iops_html | safe }}</div>
</section>

<section>
  <h2>Latency</h2>
  <div class="chart">{{ latency_html | safe }}</div>
</section>

<section>
  <h2>Diff table (vs <code>{{ baseline }}</code>)</h2>
  <table class="diff">
    <thead>
      <tr>
        <th>target</th>
        <th>workload</th>
        <th>axes</th>
        {% for run in runs %}
          <th class="num">{{ run.label }}<br>MiB/s</th>
          {% if run.label != baseline %}
            <th class="num">Δ%</th>
          {% endif %}
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in rows %}
        <tr>
          <td>{{ row.target }}</td>
          <td>{{ row.workload }}</td>
          <td class="dim">{{ row.axis_label or "—" }}</td>
          {% for run in runs %}
            {% set v = row.per_run.get(run.label, {}).get("throughput_mib_s") %}
            <td class="num">{% if v is none %}—{% else %}{{ "%.1f"|format(v) }}{% endif %}</td>
            {% if run.label != baseline %}
              {% set delta = row.delta_pct("throughput_mib_s", run.label, baseline) %}
              {% if delta is none %}
                <td class="num dim">—</td>
              {% elif delta > 0.5 %}
                <td class="num delta-pos">+{{ "%.1f"|format(delta) }}%</td>
              {% elif delta < -0.5 %}
                <td class="num delta-neg">{{ "%.1f"|format(delta) }}%</td>
              {% else %}
                <td class="num delta-zero">{{ "%.1f"|format(delta) }}%</td>
              {% endif %}
            {% endif %}
          {% endfor %}
        </tr>
      {% endfor %}
    </tbody>
  </table>
</section>

</main>

<footer>
  Generated by elbencho-harness · compare report
</footer>

</body>
</html>
